# Copy to .env.development or .env.production and fill in values

# API Configuration (REQUIRED)
VITE_API_URL=http://localhost:4010/api/v1

# App Configuration
VITE_APP_NAME=Interdiscount Admin
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_LANGUAGE=de

# Feature Flags
VITE_ENABLE_DEVTOOLS=true

# Docker proxy target (dev only)
API_PROXY_TARGET=http://localhost:4010
